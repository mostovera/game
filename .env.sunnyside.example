# Sunnyside client env (21-client §3.5). Скопируй в .env.sunnyside (в .gitignore).
# Секретный service_role ключ в клиент НИКОГДА не кладём — только publishable.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Бэкенд-адаптер: supabase (прод/интеграция) | local (эмуляция в браузере, IndexedDB).
# NET-5: в прод-сборке (import.meta.env.PROD) или при VITE_REQUIRE_SUPABASE=true откат на
# local ЗАПРЕЩЁН (fail-closed) — local клиент-авторитетен и читерски минтит ресурсы.
# Для локальной оффлайн-разработки без сервера явно поставь VITE_BACKEND_ADAPTER=local.
VITE_BACKEND_ADAPTER=supabase
# VITE_REQUIRE_SUPABASE=true
