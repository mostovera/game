# Sunnyside client env (21-client §3.5). Скопируй в .env.sunnyside (в .gitignore).
# Секретный service_role ключ в клиент НИКОГДА не кладём — только publishable.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Бэкенд-адаптер по умолчанию: local (эмуляция в браузере, IndexedDB) | supabase.
# Пустой / отсутствует URL → автоматически local.
VITE_BACKEND_ADAPTER=local
